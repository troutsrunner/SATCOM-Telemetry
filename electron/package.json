{
  "name": "satcom-telemetry-desktop",
  "version": "0.1.0",
  "description": "SATCOM Telemetry — standalone desktop application (Electron wrapper)",
  "main": "main.js",
  "scripts": {
    "setup": "cd ../app && npm install",
    "dev": "electron .",
    "start": "electron .",
    "build:app": "cd ../app && npm run build && node ../electron/scripts/copy-standalone.js",
    "dist:mac": "npm run build:app && electron-builder --mac",
    "dist:win": "npm run build:app && electron-builder --win",
    "dist:linux": "npm run build:app && electron-builder --linux"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.satcom.telemetry",
    "productName": "SATCOM Telemetry",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../app/.next/standalone",
        "to": "nextapp",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
